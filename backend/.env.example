# LLM Provider Keys
OPENAI_API_KEY="your-openai-api-key-here"
DEEPSEEK_API_KEY="your-deepseek-api-key-here"
QWEN_API_KEY="your-qwen-api-key-here"

# Git Configuration (for Commits/Push)
# Ensure the directory has correct local git config, or rely on existing SSH/HTTPS.
# For remote push if needed, might need a GitHub PAT, though if local, it uses the user's config.

# Authentication
APP_ADMIN_USERNAME="admin"
# Change this to a secure password
APP_ADMIN_PASSWORD="StrongPassword123!"
# Generate via `uv run python generate_secret.py`
APP_MFA_SECRET="JBSWY3DPEHPK3PXP"

# JWT Config
JWT_SECRET_KEY="replace-this-with-a-random-256-bit-key-e.g.-output-of-openssl-rand-hex-32"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Publish Repo (approval-gated wiki writes) ---
# Local path to the cloned publish repository (e.g. LLM_Knowledge_Base)
PUBLISH_REPO_DIR="/Users/you/Projects/LLM_Knowledge_Base"
# GitHub Personal Access Token with repo scope (for push + PR creation)
GITHUB_TOKEN=""
# GitHub repo in "owner/repo" format for PR creation
PUBLISH_REPO="WeiqiangYu0528/LLM_Knowledge_Base"

# --- Search & Embedding ---
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_EMBED_MODEL="nomic-embed-text"
EMBEDDING_DIMENSIONS=768

# --- Search ---
SEARCH_MAX_RESULTS=8
SEARCH_MAX_CHARS=2000

# --- Cache ---
CACHE_L1_MAX_ENTRIES=200
CACHE_L2_TTL_SECONDS=3600
CACHE_DB_PATH="data/cache.db"

# --- Meilisearch ---
MEILISEARCH_URL="http://localhost:7700"
MEILISEARCH_API_KEY=""

# --- Memory ---
MEMORY_DB_PATH="data/memory.db"
